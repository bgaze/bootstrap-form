{
    "name": "bgaze/bootstrap-form",
    "description": "Bootstrap 4 forms builder for Laravel 5.8+",
    "keywords": [
        "laravel",
        "form",
        "bootstrap"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Bgaze",
            "email": "benjamin@bgaze.fr"
        }
    ],
    "require": {
        "php": ">=7.2.5",
        "illuminate/support": ">=6.0",
        "illuminate/database": ">=6.0",
        "illuminate/routing": ">=6.0",
        "illuminate/session": ">=6.0",
        "illuminate/view": ">=6.0",
        "illuminate/http": ">=6.0"
    },
    "autoload": {
        "psr-4": {
            "Bgaze\\BootstrapForm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bgaze\\BootstrapForm\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bgaze\\BootstrapForm\\BootstrapFormServiceProvider"
            ],
            "aliases": {
                "BF": "Bgaze\\BootstrapForm\\Support\\Facades\\BF"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.0"
    }
}
