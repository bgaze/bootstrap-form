{
    "name": "bgaze/bootstrap-form",
    "description": "Bootstrap 4 & 5 forms builder for Laravel 12+",
    "keywords": [
        "laravel",
        "form",
        "bootstrap"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Bgaze",
            "email": "benjamin@bgaze.fr"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0 || ^13.0",
        "illuminate/database": "^12.0 || ^13.0",
        "illuminate/routing": "^12.0 || ^13.0",
        "illuminate/session": "^12.0 || ^13.0",
        "illuminate/view": "^12.0 || ^13.0",
        "illuminate/http": "^12.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "Bgaze\\BootstrapForm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Bgaze\\BootstrapForm\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bgaze\\BootstrapForm\\BootstrapFormServiceProvider"
            ],
            "aliases": {
                "BF": "Bgaze\\BootstrapForm\\Support\\Facades\\BF"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require-dev": {
        "orchestra/testbench": "^10.0 || ^11.0",
        "phpunit/phpunit": "^11.0",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0"
    }
}
